<site name="${project.name}" xmlns="http://maven.apache.org/SITE/2.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://maven.apache.org/SITE/2.0.0 https://maven.apache.org/xsd/site-2.0.0.xsd">
    <bannerLeft href="https://github.com/hazendaz">
        <image src="/images/hazendaz-banner.jpg" />
    </bannerLeft>
    <bannerRight href="https://github.com/hazendaz">
        <image src="/images/hazendaz.png" />
    </bannerRight>
    <skin>
        <groupId>org.apache.maven.skins</groupId>
        <artifactId>maven-fluido-skin</artifactId>
        <version>2.1.0</version>
    </skin>
    <custom>
        <fluidoSkin>
            <topBarEnabled>true</topBarEnabled>
            <sideBarEnabled>true</sideBarEnabled>
        </fluidoSkin>
    </custom>
    <body>
        <links>
            <item name="Hazendaz" href="https://github.com/hazendaz" />
        </links>
        <menu ref="reports" />
    </body>
</site>
